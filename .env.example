# Dynamo AI Mobile — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── Firebase Configuration ───────────────────────────────────────────────────
# Get these from your Firebase project settings:
# Firebase Console → Project Settings → General → Your apps → Web app config
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com

# ─── Notes ────────────────────────────────────────────────────────────────────
# All variables prefixed with EXPO_PUBLIC_ are embedded at build time and
# are visible in the client bundle. Only use them for non-secret config.
# 
# Firebase API keys for web/mobile clients are designed to be public —
# security is enforced by Firebase Security Rules in the Firebase Console.
#
# For Android, also place your google-services.json in the project root.
# See google-services.json.example for the required structure.
